# =========================================================
#  IBN Salem — Configuração Apache (HostGator)
#  Segurança, HTTPS e performance
# =========================================================

# ---------------------------------------------------------
# 1) Forçar HTTPS (redireciona http -> https)
# ---------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Opcional: forçar www (descomente se o domínio usar www)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# ---------------------------------------------------------
# 2) Cabeçalhos de segurança
# ---------------------------------------------------------
<IfModule mod_headers.c>
    # Obriga o navegador a usar sempre HTTPS por 1 ano (HSTS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Impede que o site seja embutido em iframes (anti-clickjacking)
    Header always set X-Frame-Options "DENY"

    # Bloqueia adivinhação de tipo de conteúdo (anti-MIME sniffing)
    Header always set X-Content-Type-Options "nosniff"

    # Não vaza a URL de origem para sites externos
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Desativa recursos sensíveis que o site não usa
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Content Security Policy (inclui frame-ancestors, que o <meta> não suporta)
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src https://fonts.gstatic.com https://cdnjs.cloudflare.com; script-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'"

    # Remove a assinatura do servidor das respostas
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ---------------------------------------------------------
# 3) Compressão (GZIP) — páginas mais leves e rápidas
# ---------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---------------------------------------------------------
# 4) Cache do navegador — carregamento mais rápido em retornos
# ---------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# ---------------------------------------------------------
# 5) Proteções extras
# ---------------------------------------------------------
# Impede listagem de arquivos das pastas (ex.: /Assets/)
Options -Indexes

# Bloqueia acesso ao próprio .htaccess e arquivos ocultos
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Página de erro personalizada
ErrorDocument 404 /404.html
